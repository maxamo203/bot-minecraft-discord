# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Opcional: si se define, los slash commands se registran solo en este guild (rápido, ideal para desarrollo).
# Si se omite, se registran globalmente (tarda hasta 1h en propagarse).
DISCORD_DEV_GUILD_ID=

# Mongo
MONGO_URI=mongodb://localhost:27017/mc-vm-bot

# Clave maestra para cifrar credenciales guardadas (Azure, SSH) en Mongo.
# Debe ser 32 bytes en hex (64 caracteres). Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
